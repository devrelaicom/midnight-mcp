# Midnight MCP - Environment Variables
# Default: hosted mode (no configuration needed)

# ─────────────────────────────────────────────────────────────────
# GitHub Tokens
# ─────────────────────────────────────────────────────────────────

# General GitHub token - increases API rate limits (60 → 5000 req/hr)
# Used by MCP server for fetching files, releases, etc.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Midnight org token - PAT with midnightntwrk org access
# Required for indexing private repos in api/scripts
# MIDNIGHT_GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────
# Optional: Override log level
# ─────────────────────────────────────────────────────────────────

# LOG_LEVEL=info                         # debug|info|warn|error

# ─────────────────────────────────────────────────────────────────
# Local Mode (optional - for privacy or offline use)
# Set MIDNIGHT_LOCAL=true to enable
# ─────────────────────────────────────────────────────────────────

# MIDNIGHT_LOCAL=true
# OPENAI_API_KEY=sk-xxxxxxxxxxxx         # Required for local embeddings
# CHROMA_URL=http://localhost:8000       # ChromaDB endpoint

# ─────────────────────────────────────────────────────────────────
# Indexing (for api/ scripts only)
# Required when running `npm run index` in api/ directory
# ─────────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-xxxxxxxxxxxx         # For generating embeddings
# CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxx     # Cloudflare account ID
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxx      # Cloudflare API token
