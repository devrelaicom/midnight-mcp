name = "midnight-mcp-api"
main = "src/index.ts"
compatibility_date = "2024-12-01"

[vars]
ENVIRONMENT = "production"
COMPACT_PLAYGROUND_URL = "https://compact-playground.fly.dev"

# Vectorize index for semantic search
[[vectorize]]
binding = "VECTORIZE"
index_name = "midnight-code"

# KV namespace for OAuth/session storage
# The deploy workflow resolves the ID by looking up a namespace named "midnight-mcp-metrics".
[[kv_namespaces]]
binding = "METRICS"
id = "__KV_NAMESPACE_ID__"

# D1 database for metrics, embedding cache, and analytics
# The deploy workflow resolves the ID by looking up a database named "midnight-mcp".
[[d1_databases]]
binding = "DB"
database_name = "midnight-mcp"
database_id = "__D1_DATABASE_ID__"

# Rate limiting — anonymous users
[[unsafe.bindings]]
name = "RATE_LIMIT_ANON"
type = "ratelimit"
namespace_id = "1001"
simple = { limit = 10, period = 60 }

# Rate limiting — authenticated users
[[unsafe.bindings]]
name = "RATE_LIMIT_AUTH"
type = "ratelimit"
namespace_id = "1002"
simple = { limit = 60, period = 60 }
