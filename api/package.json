{
  "name": "midnight-mcp-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0 <26"
  },
  "scripts": {
    "dev": "wrangler dev",
    "check-config": "node -e \"const fs=require('fs');const t=fs.readFileSync('wrangler.toml','utf8');if(/REPLACE_AFTER_CREATE/.test(t)){console.error('ERROR: Unresolved D1 placeholder in wrangler.toml.\\nRun: npx wrangler d1 create midnight-mcp — then update database_id in wrangler.toml.\\nSee README.md Step 4.');process.exit(1)}\"",
    "predeploy": "npm run check-config",
    "deploy": "wrangler deploy",
    "create-index": "wrangler vectorize create midnight-code --dimensions=1536 --metric=cosine",
    "delete-index": "wrangler vectorize delete midnight-code",
    "index": "npx tsx scripts/index-repos.ts"
  },
  "dependencies": {
    "@types/tar-stream": "^3.1.4",
    "hono": "^4.12.7",
    "tar-stream": "^3.1.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "dotenv": "^17.3.1",
    "octokit": "^5.0.5",
    "openai": "^6.27.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.72.0"
  }
}
