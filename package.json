{
  "name": "midnight-mcp",
  "version": "0.2.17",
  "description": "Model Context Protocol Server for Midnight Blockchain Development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "midnight-mcp": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup && node --import tsx scripts/update-server-json.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "start": "node dist/bin.js --stdio",
    "start:http": "node dist/bin.js --http",
    "dev": "NODE_ENV=development tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "update-server-json": "node --import tsx scripts/update-server-json.ts",
    "prepublishOnly": "npm run ci",
    "ci": "npm run typecheck && npm run typecheck:tests && npm run lint -- --max-warnings 0 && npm run format:check && npm run build && npm run test:run",
    "prepare": "husky"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "mcp",
    "model-context-protocol",
    "compact",
    "zero-knowledge",
    "ai",
    "developer-tools"
  ],
  "author": "Idris Olubisi",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chromadb": "^3.3.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-html-parser": "^7.1.0",
    "octokit": "^5.0.5",
    "openai": "^6.27.0",
    "semver": "^7.7.4",
    "turndown": "^7.2.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "@types/turndown": "^5.0.6",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tar": "^7.5.11",
    "tsup": "^8.5.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.14.0 <26"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Olanetsoft/midnight-mcp.git"
  },
  "homepage": "https://github.com/Olanetsoft/midnight-mcp#readme",
  "bugs": {
    "url": "https://github.com/Olanetsoft/midnight-mcp/issues"
  }
}
